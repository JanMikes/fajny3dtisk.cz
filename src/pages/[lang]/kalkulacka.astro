---
import CalculatorPage from '../../components/CalculatorPage.astro';
import { languages, defaultLang } from '../../i18n/config';

// Generate static paths for all languages except the default (Czech)
export function getStaticPaths() {
  return Object.entries(languages)
    .filter(([code]) => code !== defaultLang)
    .map(([code, config]) => ({
      params: { lang: config.path },
      props: { translations: config.translations, url: config.url, path: config.path },
    }));
}

const { translations: t, url, path } = Astro.props;
---

<CalculatorPage t={t} url={`${url}kalkulacka`} path={path} />
